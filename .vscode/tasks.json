{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Delphi: Compilar DEBUG",
            "type": "shell",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/c"
                    ]
                }
            },
            "command": "call \"C:\\Program Files (x86)\\Embarcadero\\Studio\\21.0\\bin\\rsvars.bat\" && msbuild \"${workspaceFolder}\\samples\\basic_ws\\BasicWsServer.dproj\" /p:Config=Debug /p:Platform=Win32 /t:Build /v:normal",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "delphi",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": {
                    "regexp": "^(.*\\.pas)\\((\\d+),(\\d+)\\):\\s+(Fatal|Error|Warning|Hint):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            }
        },
